{
  "expo": {
    "name": "Roamie",
    "slug": "roamie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-light.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.taikiyanada.roamie"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-light.png",
        "backgroundColor": "#F7F5F2"
      },
      "package": "com.taikiyanada.roamie"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Roamie uses your current location to save your home area, compare nearby places, and record location history when you allow tracking."
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Roamie would like permission to use your user ID, home area, location history, and travel mood for partner mobility insights, including sharing with data brokers."
        }
      ]
    ]
  }
}
